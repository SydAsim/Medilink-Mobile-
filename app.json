{
  "expo": {
    "name": "medilinkMobile",
    "slug": "medilinkMobile",
    "jsEngine": "hermes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medilinkmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.anonymous.medilinkMobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.medilinkMobile",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBStWiRE86cHi7j5DL9WSOK-0sVdbUBvkA"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload images of emergencies.",
          "cameraPermission": "The app accesses your camera to let you take photos of emergencies."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow MediLink to use the microphone for voice dictation.",
          "speechRecognitionPermission": "Allow MediLink to convert your speech to text for emergency reports."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e50672d3-04d5-4863-97d6-57f007a8473d"
      }
    }
  }
}
